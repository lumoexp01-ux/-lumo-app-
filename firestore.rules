rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Bloqueio padrão — negar tudo que não tem regra explícita ──────
    match /{document=**} {
      allow read, write: if false;
    }

    // ── Documento do usuário ──────────────────────────────────────────
    match /usuarios/{userId} {

      // Leitura: apenas o próprio usuário autenticado
      allow read: if request.auth != null
                  && request.auth.uid == userId;

      // Criação: campo `pagamento` proibido no frontend.
      // Cloud Function ativarTrial() escreve `pagamento` via Admin SDK,
      // que ignora estas regras — esse é o único caminho permitido.
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && !('pagamento' in request.resource.data)
                    && 'perfil' in request.resource.data
                    && request.resource.data.perfil.nome is string
                    && request.resource.data.perfil.nome.size() < 100
                    && request.resource.data.perfil.email is string
                    && request.resource.data.perfil.email.size() < 200;

      // Atualização: campo `pagamento` nunca alterável pelo frontend.
      // Dupla proteção: (1) pagamento não pode mudar, (2) usuário precisa ter acesso ativo.
      // Isso garante que mesmo offline, sem internet ou bloqueando a CF,
      // o Firestore rejeita qualquer escrita de quem não tem trial/assinatura válidos.
      // trialFim é Timestamp nativo — comparável com request.time.
      allow update: if request.auth != null
                    && request.auth.uid == userId
                    && !('pagamento' in request.resource.data.diff(resource.data).affectedKeys())
                    && 'pagamento' in resource.data
                    && (
                         resource.data.pagamento.pago == true
                         || (
                              resource.data.pagamento.trial == true
                              && resource.data.pagamento.trialFim > request.time
                            )
                       );
    }

    // ── triaisUsados — coleção anti-abuso de trial ────────────────────
    // Escrita e leitura SOMENTE via Admin SDK (Cloud Functions).
    // Frontend jamais acessa esta coleção.
    match /triaisUsados/{docId} {
      allow read, write: if false;
    }

    // ── contadores de rate limiting ───────────────────────────────────
    // Cada usuário só acessa seus próprios contadores (uid_data).
    match /contadores/{contadorId} {
      allow read, write: if request.auth != null
                         && contadorId.matches(request.auth.uid + '_.*');
    }

    // ── config-app — configurações globais do app (link Discord etc.) ─
    // Leitura por qualquer usuário autenticado.
    // Escrita SOMENTE via Admin SDK (Firebase Console ou Cloud Functions).
    match /config-app/{docId} {
      allow read:  if request.auth != null;
      allow write: if false;
    }
  }
}
